<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mascotared.Views.TaskPopup"
             Title="TaskPopup"
             BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#1C1F2E}">
    <ContentPage.Resources>

        <Style x:Key="PopupLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
        </Style>
        <Style x:Key="PopupValue" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="InterSemiBold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </ContentPage.Resources>

    <Grid>

        <!-- CAPA 1: Lista -->
        <VerticalStackLayout Spacing="0">

            <!-- Filtros -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                    Padding="16,14,16,10">
                <HorizontalStackLayout Spacing="8">
                    <Border x:Name="allRequests" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Stroke="Transparent" Padding="16,8">
                        <Label Text="Todos" FontFamily="InterSemiBold" FontSize="13" TextColor="White" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Todos" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="propRequests" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="Solicitudes de cuidado" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Solicitudes de cuidado" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="helperRequests" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="Tu cuidado" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Tu Cuidado" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="completedRequests" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="Completadas" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Completadas" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="otrasRequests" StrokeShape="RoundRectangle 20"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="Otras solicitudes" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Otras Solicitudes" />
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Estado vacío -->
            <VerticalStackLayout x:Name="EstadoVacio" IsVisible="False"
                             HorizontalOptions="Center" Spacing="12" Margin="0,80,0,0">
                <Label Text="🐾" FontSize="52" HorizontalOptions="Center" />
                <Label Text="Aún no tienes solicitudes de cuidado" FontFamily="InterSemiBold"
                   FontSize="16" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" HorizontalOptions="Center" />
                <Label Text="Pulsa el botón + para añadir tu primera solicitud"
                   FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                   HorizontalTextAlignment="Center" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Grid de tarjetas -->
            <CollectionView x:Name="GridMascotas" Margin="12,4,12,90"
                        SelectionMode="Single" SelectionChanged="OnTaskSeleccionada">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="0,0,0,12" Margin="0,0,0,2">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsFinished}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#E0E0E0" />
                                    <Setter Property="Opacity" Value="0.65" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="0">
                                <Border StrokeShape="RoundRectangle 14,14,0,0"
                                    Stroke="Transparent" HeightRequest="120">
                                    <Image Source="{Binding photoPath}" Aspect="AspectFill" HeightRequest="120">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding photoPath}" Value="">
                                                <Setter Property="Source" Value="placeholder_pet.png" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>
                                </Border>
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Stroke="Transparent" Padding="8,4"
                                    HorizontalOptions="Start" Margin="10,8,10,4">
                                    <Label FontSize="11" FontFamily="InterSemiBold"
                                           TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding caretaker}" Value="True">
                                                <Setter Property="Text" Value="Cuidador/a" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding caretaker}" Value="False">
                                                <Setter Property="Text" Value="Propietario/a" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                                <Label Text="{Binding title}" FontFamily="InterSemiBold"
                                   FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                                   Margin="10,0,10,2" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding userLocation}" FontSize="12"
                                   TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" Margin="10,0,10,4"
                                   LineBreakMode="TailTruncation" />
                                <Label FontSize="12" FontFamily="InterSemiBold"
                                   TextColor="#22AA55" Margin="10,0,10,0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding caretaker}" Value="True">
                                            <Setter Property="Text" Value="{Binding perHour, StringFormat='{0:F2} €/h'}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding caretaker}" Value="False">
                                            <Setter Property="Text" Value="{Binding totalPrice, StringFormat='{0:F2} €'}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Lista de solicitudes enviadas (tab Otras Solicitudes) -->
            <CollectionView x:Name="ListaSolicitudes" IsVisible="False" Margin="12,4,12,90">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" StrokeShape="RoundRectangle 16"
                                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,14" Margin="0,0,0,10">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Estado}" Value="Completada">
                                    <Setter Property="BackgroundColor" Value="#E0E0E0" />
                                    <Setter Property="Opacity" Value="0.65" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}" Stroke="Transparent"
                                            Padding="8,4" HorizontalOptions="Start">
                                        <Label Text="{Binding OfertaTitulo}" FontFamily="InterSemiBold"
                                               FontSize="13" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                                               LineBreakMode="TailTruncation" />
                                    </Border>
                                    <Label Grid.Column="1" Text="{Binding Estado}"
                                           FontFamily="InterSemiBold" FontSize="12"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Pendiente">
                                                <Setter Property="TextColor" Value="#F5A623" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Aceptada">
                                                <Setter Property="TextColor" Value="#22AA55" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Rechazada">
                                                <Setter Property="TextColor" Value="#FE3D7D" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Completada">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                                <Label Text="{Binding AutorNombre}" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                <Label Text="{Binding OfertaLocalizacion}" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                        Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="12,8"
                                        HorizontalOptions="Start">
                                    <Label Text="Cancelar solicitud" FontFamily="InterSemiBold"
                                           FontSize="12" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelarCommand}"
                                                CommandParameter="{Binding Id}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Botón flotante + -->
        <Border StrokeShape="RoundRectangle 28" BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
            Stroke="Transparent" WidthRequest="56" HeightRequest="56"
            HorizontalOptions="End" VerticalOptions="End" Margin="0,0,24,96">
            <Border.Shadow>
                <Shadow Brush="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" Opacity="0.4" Offset="0,4" Radius="12" />
            </Border.Shadow>
            <Label Text="+" FontSize="30" FontFamily="InterSemiBold" TextColor="White"
               HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAnadirTaskTapped" />
            </Border.GestureRecognizers>
        </Border>

        <!-- Barra de navegación inferior -->
        <Grid BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
              ColumnDefinitions="*,*,*,*,*" Padding="0,10,0,30"
              VerticalOptions="End">
            <Grid.Shadow>
                <Shadow Brush="Black" Opacity="0.06" Offset="0,-4" Radius="12" />
            </Grid.Shadow>
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                <Label Text="🔍" FontSize="22" HorizontalOptions="Center" />
                <Label Text="Buscar" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBuscarTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                <Label Text="🤍" FontSize="22" HorizontalOptions="Center" />
                <Label Text="Favoritos" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFavoritosTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                <Label Text="📅" FontSize="22" HorizontalOptions="Center" />
                <Label Text="Solicitudes" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReservasTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                <Grid HorizontalOptions="Center">
                    <Label Text="💬" FontSize="22" HorizontalOptions="Center" />
                    <Border x:Name="BadgeNoLeidos"
                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                            StrokeShape="Ellipse"
                            Stroke="White" StrokeThickness="1.5"
                            WidthRequest="10" HeightRequest="10"
                            HorizontalOptions="End" VerticalOptions="Start"
                            IsVisible="False" />
                </Grid>
                <Label Text="Mensajes" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMensajesTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4">
                <Label Text="👤" FontSize="22" HorizontalOptions="Center" />
                <Label Text="Cuenta" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCuentaTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

        <!-- CAPA 2: Overlay oscuro -->
        <BoxView x:Name="DimOverlay" Color="#80000000" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCerrarPopupTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- CAPA 3: Popup bottom sheet -->
        <Border x:Name="PopupDetalle" IsVisible="False"
            StrokeShape="RoundRectangle 24" BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
            Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}"
            HorizontalOptions="Fill" VerticalOptions="End">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Cabecera con foto -->
                <Grid Grid.Row="0">
                    <Image x:Name="PopupFoto" HeightRequest="200"
                       Aspect="AspectFill" HorizontalOptions="Fill" />
                    <BoxView VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#CC000000" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <VerticalStackLayout VerticalOptions="End" Padding="16,12">
                        <Label x:Name="PopupTitle" FontFamily="InterSemiBold"
                           FontSize="22" TextColor="White" />
                        <Label x:Name="PopupLocation" FontSize="13" TextColor="#CCFFFFFF" />
                    </VerticalStackLayout>
                    <Border StrokeShape="RoundRectangle 20" BackgroundColor="#22000000"
                        Stroke="Transparent" WidthRequest="36" HeightRequest="36"
                        VerticalOptions="Start" HorizontalOptions="End" Margin="0,12,12,0">
                        <Label Text="✕" FontSize="15" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCerrarPopupTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Cuerpo -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="360">
                    <VerticalStackLayout x:Name="PopupContenido" Padding="20,16" Spacing="0">

                        <FlexLayout x:Name="PopupPills" Wrap="Wrap"
                                JustifyContent="Start" AlignItems="Start"
                                Margin="0,0,0,16" />

                        <Label Text="INFORMACIÓN BÁSICA" FontFamily="InterSemiBold"
                           FontSize="11" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                           Margin="0,0,0,8" />

                        <!-- ESPECÍFICO: PROPIETARIO -->
                        <Border x:Name="PopupProp" IsVisible="False">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="Fecha de cuidado" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupCareDate" Style="{StaticResource PopupValue}" />
                                <Label Text="Horas exactas" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupExactTime" Style="{StaticResource PopupValue}" />
                                <Label Text="Horario" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupSchedule" Style="{StaticResource PopupValue}" />
                                <Label x:Name="PetsData" Text="Información de las mascotas"
                                   FontFamily="InterSemiBold" FontSize="11"
                                   TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Margin="0,8,0,8" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                    <Label Grid.Column="0" Text="MIS MASCOTAS" FontFamily="OpenSansSemibold"
                                        FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" CharacterSpacing="1"
                                        VerticalOptions="Center" />
                                    <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                        Padding="10,5" Stroke="Transparent" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14"/>
                                        </Border.StrokeShape>
                                        <Label Text="+ Añadir" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnAnadirTaskTapped" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Border>
                                </Grid>
                                <VerticalStackLayout x:Name="StackMascotas" Spacing="10" Margin="0,0,0,24" />
                                <Label Text="Sobre cuidados especiales" FontFamily="InterSemiBold"
                                   FontSize="11" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Margin="0,8,0,8" />
                                <Label Text="Cuidados especiales" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupSpecialNeeds" Style="{StaticResource PopupValue}" />
                                <Label x:Name="PopupSpecialNeedsDesc" Style="{StaticResource PopupValue}" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- ESPECÍFICO: CUIDADOR -->
                        <Border x:Name="PopupCare" IsVisible="False">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="Horario" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupWeekCare" Style="{StaticResource PopupValue}" />
                                <Label x:Name="PopupScheduleCare" Style="{StaticResource PopupValue}" />
                                <Label Text="Información de las mascotas" FontFamily="InterSemiBold"
                                   FontSize="11" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Margin="0,8,0,8" />
                                <Label Text="¿Ha tenido?" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupHadPets" Style="{StaticResource PopupValue}" />
                                <Label Text="Número máximo dispuesto a cuidar" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupMaxPets" Style="{StaticResource PopupValue}" />
                                <Label Text="Dispuesto a cuidar" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupPetCare" Style="{StaticResource PopupValue}" />
                                <Label Text="Sobre cuidados especiales" FontFamily="InterSemiBold"
                                   FontSize="11" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Margin="0,8,0,8" />
                                <Label Text="Experiencia" Style="{StaticResource PopupLabel}" />
                                <Label x:Name="PopupSpecialNeedsCare" Style="{StaticResource PopupValue}" />
                                <Label x:Name="PopupSpecialNeedsXP" Style="{StaticResource PopupValue}" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- ══ SECCIÓN RESEÑAS DEL AUTOR ══════════════════════════════════ -->
                        <!-- Se oculta si el autor no tiene reseñas. LabelResenasHeader      -->
                        <!-- muestra la media y el total. StackResenas se rellena desde C#. -->
                        <VerticalStackLayout x:Name="SeccionResenas"
                                             IsVisible="False"
                                             Spacing="8"
                                             Margin="0,16,0,0">
                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}"
                                     Margin="0,0,0,8" />
                            <Label Text="VALORACIONES DEL AUTOR"
                                   FontFamily="InterSemiBold"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                   CharacterSpacing="1" />
                            <Label x:Name="LabelResenasHeader"
                                   FontFamily="InterSemiBold"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                            <VerticalStackLayout x:Name="StackResenas" Spacing="6" />
                        </VerticalStackLayout>
                        <!-- ══════════════════════════════════════════════════════════════ -->

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Zona inferior: completada / solicitudes recibidas / botones -->
                <VerticalStackLayout Grid.Row="2" Spacing="0">

                    <!-- Etiqueta completada -->
                    <Border x:Name="LabelCompletada" IsVisible="False"
                        StrokeShape="RoundRectangle 12" BackgroundColor="#F0FFF5"
                        Stroke="#22AA55" Padding="16,10" Margin="20,8,20,0">
                        <Label Text="✅  Tarea completada" FontFamily="InterSemiBold"
                           FontSize="14" TextColor="#22AA55" HorizontalOptions="Center" />
                    </Border>

                    <!-- Sección solicitudes recibidas -->
                    <VerticalStackLayout x:Name="SeccionSolicitudesRecibidas"
                                     IsVisible="False" Padding="20,12,20,0" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="SOLICITUDES RECIBIDAS"
                               FontFamily="InterSemiBold" FontSize="11"
                               TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" VerticalOptions="Center"
                               CharacterSpacing="1" />
                            <Border Grid.Column="1" x:Name="BtnVerSolicitudes"
                                StrokeShape="RoundRectangle 10" IsVisible="False"
                                BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="10,5">
                                <Label Text="Ver / ocultar" FontSize="12"
                                   TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnVerSolicitudesTapped" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <VerticalStackLayout x:Name="StackSolicitudesRecibidas" Spacing="6" />
                    </VerticalStackLayout>

                    <!-- Botones acción -->
                    <VerticalStackLayout x:Name="BotonesAccion"
                                     IsVisible="False" Padding="20,10,20,20" Spacing="10">
                        <Grid ColumnDefinitions="*,12,*">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                            Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="0,14">
                                <Label Text="✏️  Editar" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                               HorizontalOptions="Center" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEditarDesdePupupTapped" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="2" StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                            Stroke="Transparent" Padding="0,14">
                                <Label Text="🗑️  Eliminar" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="White"
                               HorizontalOptions="Center" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEliminarTapped" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <Border x:Name="BtnFinalizar" StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                            Stroke="Transparent" Padding="0,14">
                            <Label Text="✅  Marcar como completada" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="White"
                               HorizontalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFinalizarTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Botón Completar (cuidador aceptado, tarea activa) -->
                    <Border x:Name="BtnCompletar" IsVisible="False"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#22AA55"
                            Stroke="Transparent" Padding="0,14"
                            Margin="20,10,20,20">
                        <Label Text="✅  He completado esta tarea" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="White"
                               HorizontalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCompletarTapped" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Botón Dejar Reseña (cuidador aceptado, tarea finalizada) -->
                    <Border x:Name="BtnDejarResena" IsVisible="False"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="#F59E0B"
                            Stroke="Transparent" Padding="0,14"
                            Margin="20,0,20,20">
                        <Label Text="⭐  Dejar reseña" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="White"
                               HorizontalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDejarResenaTapped" />
                        </Border.GestureRecognizers>
                    </Border>

                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
