<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mascotared.Views.MisMascotasLista"
             Title="Mis Mascotas"
             BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#1C1F2E}">

    <ContentPage.Resources>
        <Style x:Key="PopupLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
        </Style>
        <Style x:Key="PopupValue" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="InterSemiBold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SeccionPopup" TargetType="Label">
            <Setter Property="FontFamily" Value="InterSemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- CAPA 1: Lista -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">

            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                        Padding="16,14,16,10">
                <HorizontalStackLayout Spacing="8">
                    <Border x:Name="ChipTodos" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Stroke="Transparent" Padding="16,8">
                        <Label Text="Todos" FontFamily="InterSemiBold" FontSize="13" TextColor="White" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTapped" CommandParameter="Todos" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="ChipPerro" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="🐶 Perros" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTapped" CommandParameter="Perro" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="ChipGato" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="🐱 Gatos" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTapped" CommandParameter="Gato" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="ChipAve" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="🦜 Aves" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTapped" CommandParameter="Ave" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border x:Name="ChipOtros" StrokeShape="RoundRectangle 20"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="16,8">
                        <Label Text="🐾 Otros" FontFamily="InterSemiBold" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTapped" CommandParameter="Otros" />
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <VerticalStackLayout x:Name="EstadoVacio" IsVisible="False"
                                 HorizontalOptions="Center" Spacing="12" Margin="0,80,0,0">
                <Label Text="🐾" FontSize="52" HorizontalOptions="Center" />
                <Label Text="Aún no tienes mascotas" FontFamily="InterSemiBold"
                       FontSize="16" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" HorizontalOptions="Center" />
                <Label Text="Pulsa el botón + para añadir tu primera mascota"
                       FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                       HorizontalTextAlignment="Center" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <CollectionView x:Name="GridMascotas" Margin="12,4,12,16"
                            SelectionMode="Single" SelectionChanged="OnMascotaSeleccionada">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" StrokeShape="RoundRectangle 16"
                                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="0,0,0,12">
                            <VerticalStackLayout Spacing="0">
                                <Border StrokeShape="RoundRectangle 14,14,0,0"
                                        Stroke="Transparent" HeightRequest="140">
                                    <Image Source="{Binding PhotoPath}" Aspect="AspectFill" HeightRequest="140">
                                        <Image.Triggers>
                                            <DataTrigger TargetType="Image" Binding="{Binding PhotoPath}" Value="{x:Null}">
                                                <Setter Property="Source" Value="placeholder_pet.png" />
                                            </DataTrigger>
                                        </Image.Triggers>
                                    </Image>
                                </Border>
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                        Stroke="Transparent" Padding="8,4"
                                        HorizontalOptions="Start" Margin="10,8,10,4">
                                    <Label Text="{Binding Especie}" FontSize="11"
                                           FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                                </Border>
                                <Label Text="{Binding Name}" FontFamily="InterSemiBold"
                                       FontSize="15" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" Margin="10,0,10,2" />
                                <Label Text="{Binding Race}" FontSize="12"
                                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" Margin="10,0,10,0" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Botón flotante + -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 28" BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                Stroke="Transparent" WidthRequest="56" HeightRequest="56"
                HorizontalOptions="End" VerticalOptions="End" Margin="0,0,24,16">
            <Border.Shadow>
                <Shadow Brush="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" Opacity="0.4" Offset="0,4" Radius="12" />
            </Border.Shadow>
            <Label Text="+" FontSize="30" FontFamily="InterSemiBold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0" />
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAnadirMascotaTapped" />
            </Border.GestureRecognizers>
        </Border>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="1" BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
              ColumnDefinitions="*,*,*,*,*" Padding="0,10,0,30">
            <Grid.Shadow>
                <Shadow Brush="Black" Opacity="0.06" Offset="0,-4" Radius="12" />
            </Grid.Shadow>
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                <Image Source="search" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Buscar" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBuscarTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                <Image Source="heart" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Favoritos" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFavoritosTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                <Image Source="calendar" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Solicitudes" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReservasTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                <Grid HorizontalOptions="Center">
                    <Image Source="message" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                    <Border x:Name="BadgeNoLeidos"
                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                            StrokeShape="Ellipse"
                            Stroke="White" StrokeThickness="1.5"
                            WidthRequest="10" HeightRequest="10"
                            HorizontalOptions="End" VerticalOptions="Start"
                            IsVisible="False" />
                </Grid>
                <Label Text="Mensajes" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMensajesTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4">
                <Image Source="user" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Cuenta" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCuentaTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

        <!-- Overlay oscuro -->
        <BoxView x:Name="DimOverlay" Grid.Row="0" Grid.RowSpan="2"
                 Color="#80000000" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCerrarPopupTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- POPUP bottom sheet -->
        <Border x:Name="PopupDetalle" Grid.Row="0" Grid.RowSpan="2"
                IsVisible="False"
                StrokeShape="RoundRectangle 24" BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}"
                HorizontalOptions="Fill" VerticalOptions="End">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Cabecera con foto -->
                <Grid Grid.Row="0">
                    <Image x:Name="PopupFoto" HeightRequest="200"
                           Aspect="AspectFill" HorizontalOptions="Fill" />
                    <BoxView VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#CC000000" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <VerticalStackLayout VerticalOptions="End" Padding="16,12">
                        <Label x:Name="PopupNombre" FontFamily="InterSemiBold"
                               FontSize="22" TextColor="White" />
                        <Label x:Name="PopupEspecie" FontSize="13" TextColor="#CCFFFFFF" />
                    </VerticalStackLayout>
                    <Border StrokeShape="RoundRectangle 20" BackgroundColor="#22000000"
                            Stroke="Transparent" WidthRequest="36" HeightRequest="36"
                            VerticalOptions="Start" HorizontalOptions="End" Margin="0,12,12,0">
                        <Label Text="✕" FontSize="15" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCerrarPopupTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Cuerpo -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="460">
                    <VerticalStackLayout Padding="20,16" Spacing="0">

                        <!-- Pills raza, sexo, peso -->
                        <FlexLayout x:Name="PopupPills" Wrap="Wrap"
                                    JustifyContent="Start" AlignItems="Start"
                                    Margin="0,0,0,12" />

                        <!-- Pills personalidad -->
                        <FlexLayout x:Name="PopupTagsPersonalidad" Wrap="Wrap"
                                    Direction="Row" Margin="0,0,0,16" />

                        <!-- INFORMACIÓN BÁSICA -->
                        <Label Text="INFORMACIÓN BÁSICA" Style="{StaticResource SeccionPopup}" />
                        <Label Text="Fecha de nacimiento" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupFechaNac" Style="{StaticResource PopupValue}" />
                        <Label Text="Edad" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupEdad" Style="{StaticResource PopupValue}" />
                        <Label Text="Estado reproductivo" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupReproductivo" Style="{StaticResource PopupValue}" />
                        <Label Text="Color y marcas" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupColor" Style="{StaticResource PopupValue}" />

                        <!-- SALUD Y NECESIDADES -->
                        <Label Text="SALUD Y NECESIDADES" Style="{StaticResource SeccionPopup}" />

                        <Label x:Name="SecAlergias" Text="Alergias" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupAlergias" Style="{StaticResource PopupValue}" />

                        <Label x:Name="SecCondiciones" Text="Condiciones médicas" Style="{StaticResource PopupLabel}" />
                        <FlexLayout x:Name="PopupCondicionesPills" Wrap="Wrap"
                                    Direction="Row" Margin="0,0,0,10" />

                        <Label x:Name="SecMovilidad" Text="Movilidad" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupMovilidad" Style="{StaticResource PopupValue}" />

                        <Label x:Name="SecAlimProhibidos" Text="Alimentos prohibidos" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupAlimProhibidos" Style="{StaticResource PopupValue}" />

                        <!-- VETERINARIO -->
                        <Label x:Name="SecVetHeader" Text="VETERINARIO"
                               Style="{StaticResource SeccionPopup}" />
                        <Label x:Name="PopupVetNombre" Style="{StaticResource PopupValue}" />
                        <Label x:Name="PopupVetDir" Style="{StaticResource PopupValue}" />
                        <Label x:Name="PopupVetTel" Style="{StaticResource PopupValue}" />

                        <!-- COMPORTAMIENTO -->
                        <Label Text="COMPORTAMIENTO" Style="{StaticResource SeccionPopup}" />
                        <Label Text="Miedos / Reactividad" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupMiedos" Style="{StaticResource PopupValue}" />
                        <Label Text="Correa / Arnés" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupCorrea" Style="{StaticResource PopupValue}" />
                        <Label Text="Socialización" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupSocial" Style="{StaticResource PopupValue}" />

                        <!-- CUIDADOS -->
                        <Label Text="CUIDADOS" Style="{StaticResource SeccionPopup}" />
                        <Label Text="Nivel de energía" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupEnergia" Style="{StaticResource PopupValue}" />
                        <Label Text="Alimentación" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupAlim" Style="{StaticResource PopupValue}" />
                        <Label Text="Medicación" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupMed" Style="{StaticResource PopupValue}" />

                        <!-- EMERGENCIA -->
                        <Label x:Name="SecEmergencia" Text="EMERGENCIA"
                               Style="{StaticResource SeccionPopup}" />
                        <Label Text="Centro de urgencias" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupUrgencias" Style="{StaticResource PopupValue}" />
                        <Label Text="Teléfono urgencias" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupTelUrgencias" Style="{StaticResource PopupValue}" />
                        <Label Text="Presupuesto autorizado" Style="{StaticResource PopupLabel}" />
                        <Label x:Name="PopupPresupuesto" Style="{StaticResource PopupValue}" />

                        <!-- NOTAS -->
                        <Label Text="NOTAS" Style="{StaticResource SeccionPopup}" />
                        <Label x:Name="PopupNotas" Style="{StaticResource PopupValue}" />

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Botones acción -->
                <Grid Grid.Row="2" ColumnDefinitions="*,12,*" Padding="20,12,20,20">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                            Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="0,14">
                        <Label Text="Editar" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                               HorizontalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEditarDesdePupupTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                            Stroke="Transparent" Padding="0,14">
                        <Label Text="Eliminar" FontFamily="InterSemiBold"
                               FontSize="14" TextColor="White"
                               HorizontalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEliminarTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</ContentPage>