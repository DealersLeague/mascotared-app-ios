<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Mascotared"
             xmlns:conv="clr-namespace:Mascotared.Converters"
             x:Class="Mascotared.MainPage"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1F2E}">

    <ContentPage.Resources>
        <Color x:Key="Green">#2DCE89</Color>
        <local:BoolToHeartConverter x:Key="BoolToHeartConverter" />
        <local:BoolToBookmarkConverter x:Key="BoolToBookmarkConverter" />
        <conv:Base64ToImageSourceConverter x:Key="Base64Conv" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1F2E}"
              Padding="20,0,20,14"
              ColumnDefinitions="*,Auto">
            <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="0">
                <Label Text="Mascota" FontFamily="InterSemiBold" FontSize="22" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                <Label Text="Red"     FontFamily="InterSemiBold" FontSize="22" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" />
            </HorizontalStackLayout>
            <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                    WidthRequest="38" HeightRequest="38"
                    Stroke="Transparent" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="19" />
                </Border.StrokeShape>
                <Label Text="💬" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMensajesTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- CONTENIDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- SECCIÓN: Cuidadores cercanos -->
                <Grid ColumnDefinitions="*,Auto" Padding="20,20,20,12">
                    <Label Grid.Column="0" Text="Cuidadores cercanos"
                           FontFamily="InterSemiBold" FontSize="17"
                           TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}" />
                    <Label Grid.Column="1" Text="Ver todos ›"
                           FontSize="13" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVerTodosCuidadoresTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView x:Name="ListaCuidadores"
                                ItemsLayout="HorizontalList"
                                HeightRequest="200"
                                Margin="14,0,0,0"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,0,12,0" WidthRequest="160">
                                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2E}"
                                        Padding="0"
                                        Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.08" Offset="0,2" Radius="8" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCuidadorTapped"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="0">
                                        <Grid HeightRequest="110" BackgroundColor="{AppThemeBinding Light=#E8EAFF, Dark=#1E2040}">
                                            <Label Text="{Binding Inicial}"
                                                   FontFamily="OpenSansSemibold" FontSize="36"
                                                   TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                            <Border IsVisible="{Binding Online}"
                                                    BackgroundColor="{StaticResource Green}"
                                                    WidthRequest="14" HeightRequest="14"
                                                    Stroke="White" StrokeThickness="1"
                                                    HorizontalOptions="End" VerticalOptions="Start"
                                                    Margin="0,8,8,0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="7" />
                                                </Border.StrokeShape>
                                            </Border>
                                            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                                                    WidthRequest="28" HeightRequest="28"
                                                    Padding="0"
                                                    Stroke="Transparent" StrokeThickness="0"
                                                    HorizontalOptions="End" VerticalOptions="End"
                                                    Margin="0,0,8,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14" />
                                                </Border.StrokeShape>
                                                <Label Text="♡" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                                                       FontSize="13"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                        <VerticalStackLayout Padding="10,8" Spacing="2">
                                            <Label Text="{Binding Nombre}"
                                                   FontFamily="OpenSansSemibold" FontSize="13"
                                                   TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}"
                                                   LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="EUR" FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                                <Label Text="{Binding TarifaPorHora}"
                                                       FontFamily="OpenSansSemibold" FontSize="11"
                                                       TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                                                <Label Text="·" FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                                <Label Text="{Binding Tag}" FontSize="11"
                                                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                                                       LineBreakMode="TailTruncation" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="2">
                                                <Label Text="★" TextColor="#FFB800" FontSize="11" />
                                                <Label Text="{Binding Valoracion}"
                                                       FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                                <Label Text="{Binding ResenasTxt}"
                                                       FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- SECCIÓN: Mascotas por dueño -->
                <Grid ColumnDefinitions="*,Auto" Padding="20,24,20,12">
                    <Label Grid.Column="0" Text="Mascotas por dueño"
                           FontFamily="InterSemiBold" FontSize="17"
                           TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}" />
                    <Label Grid.Column="1" Text="Ver todos ›"
                           FontSize="13" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVerTodasMascotasTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView x:Name="ListaMascotas"
                                ItemsLayout="HorizontalList"
                                HeightRequest="190"
                                Margin="14,0,0,16"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,0,12,0" WidthRequest="150">
                                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2E}"
                                        Padding="0"
                                        Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.08" Offset="0,2" Radius="8" />
                                    </Border.Shadow>
                                    <VerticalStackLayout Spacing="0">
                                        <Image Source="{Binding ImagenUrl, Converter={StaticResource Base64Conv}}"
                                               HeightRequest="115"
                                               Aspect="AspectFill" />
                                        <VerticalStackLayout Padding="10,8" Spacing="1">
                                            <Label Text="{Binding Nombre}"
                                                   FontFamily="OpenSansSemibold" FontSize="13"
                                                   TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}" />
                                            <Label Text="{Binding Dueno}"
                                                   FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- SECCIÓN: For You -->
                <Grid ColumnDefinitions="*,Auto" Padding="20,8,20,12">
                    <Label Grid.Column="0" Text="For you"
                           FontFamily="InterSemiBold" FontSize="17"
                           TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="+"
                            FontSize="22"
                            TextColor="White"
                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                            CornerRadius="20"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            Clicked="OnAnadirFotoTapped" />
                </Grid>

                <CollectionView x:Name="ListaFeed"
                                SelectionMode="None"
                                Margin="0,0,0,16">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="0" Margin="0,0,0,24">

                                <!-- Cabecera del post -->
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Padding="16,10" ColumnSpacing="12">
                                    <Grid Grid.Column="0" WidthRequest="44" HeightRequest="44">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnAutorTapped"
                                                                  CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <!-- Círculo con inicial -->
                                        <Border BackgroundColor="{AppThemeBinding Light=#E8EAFF, Dark=#1E2040}"
                                                WidthRequest="44" HeightRequest="44"
                                                Stroke="Transparent" StrokeThickness="0"
                                                IsVisible="{Binding TieneFoto, Converter={StaticResource InverseBoolConverter}}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="22" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding UsuarioInicial}"
                                                   FontFamily="OpenSansSemibold" FontSize="18"
                                                   TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>

                                        <!-- Foto de perfil -->
                                        <Image Source="{Binding UsuarioFotoSource}"
                                               WidthRequest="44" HeightRequest="44"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding TieneFoto}">
                                            <Image.Clip>
                                                <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22" />
                                            </Image.Clip>
                                        </Image>

                                    </Grid>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnAutorTapped"
                                                                  CommandParameter="{Binding .}" />
                                        </VerticalStackLayout.GestureRecognizers>
                                        <Label Text="{Binding UsuarioNombre}"
                                               FontFamily="OpenSansSemibold" FontSize="14"
                                               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}" />
                                        <Label Text="{Binding TiempoPublicado}"
                                               FontSize="12" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="···" FontSize="22"
                                           TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnOpcionesPostTapped"
                                                                  CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>

                                <!-- Foto ancho completo -->
                                <Image Source="{Binding ImagenUrl, Converter={StaticResource Base64Conv}}"
                                       Aspect="AspectFill"
                                       HeightRequest="380"
                                       HorizontalOptions="Fill">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnGuardarFotoTapped"
                                                              CommandParameter="{Binding .}" />
                                    </Image.GestureRecognizers>
                                </Image>

                                <!-- Acciones -->
                                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                                      Padding="14,10" ColumnSpacing="14">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                        <Label Text="{Binding MeGusta, Converter={StaticResource BoolToHeartConverter}}"
                                               FontSize="24" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnLikeFeedTapped"
                                                                      CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Text="{Binding NumLikes}"
                                               FontFamily="OpenSansSemibold" FontSize="13"
                                               TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                        <Label Text="💬" FontSize="22">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnComentarTapped"
                                                                      CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Text="{Binding NumComentarios}"
                                               FontFamily="OpenSansSemibold" FontSize="13"
                                               TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    
                                </Grid>

                                <!-- Descripción -->
                                <VerticalStackLayout Padding="16,0,16,6" Spacing="2">
                                    <Label FontSize="14"
                                           TextColor="{AppThemeBinding Light=#2C2C2C, Dark=#F0F0F0}"
                                           LineBreakMode="TailTruncation" MaxLines="2">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding UsuarioNombre}" FontFamily="OpenSansSemibold" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Descripcion}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#EEF0FB, Dark=#2C2C2E}" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <Grid Grid.Row="2" BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
              ColumnDefinitions="*,*,*,*,*" Padding="0,10,0,30">
            <Grid.Shadow>
                <Shadow Brush="Black" Opacity="0.06" Offset="0,-4" Radius="12" />
            </Grid.Shadow>
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                <Image Source="search" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Explorar" FontSize="10" FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" HorizontalOptions="Center" />
                <BoxView HeightRequest="3" WidthRequest="30" BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" CornerRadius="1.5" HorizontalOptions="Center" Margin="0,2,0,0" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBuscarTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                <Image Source="heart" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Favoritos" FontSize="10" FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <BoxView HeightRequest="3" WidthRequest="30" BackgroundColor="Transparent" CornerRadius="1.5" HorizontalOptions="Center" Margin="0,2,0,0" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFavoritosTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                <Image Source="calendar" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Solicitudes" FontSize="10" FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <BoxView HeightRequest="3" WidthRequest="30" BackgroundColor="Transparent" CornerRadius="1.5" HorizontalOptions="Center" Margin="0,2,0,0" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReservasTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                <Grid HorizontalOptions="Center">
                    <Image Source="message" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                    <Border x:Name="BadgeNoLeidos"
                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                            StrokeShape="Ellipse"
                            Stroke="White" StrokeThickness="1.5"
                            WidthRequest="10" HeightRequest="10"
                            HorizontalOptions="End" VerticalOptions="Start"
                            IsVisible="False" />
                </Grid>
                <Label Text="Mensajes" FontSize="10" FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <BoxView HeightRequest="3" WidthRequest="30" BackgroundColor="Transparent" CornerRadius="1.5" HorizontalOptions="Center" Margin="0,2,0,0" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMensajesTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4">
                <Image Source="user" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Cuenta" FontSize="10" FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <BoxView HeightRequest="3" WidthRequest="30" BackgroundColor="Transparent" CornerRadius="1.5" HorizontalOptions="Center" Margin="0,2,0,0" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCuentaTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>