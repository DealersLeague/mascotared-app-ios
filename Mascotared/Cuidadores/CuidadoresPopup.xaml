<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Mascotared.CuidadoresPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#88000000"
    Shell.NavBarIsVisible="False">
    <ScrollView>
        <Grid RowDefinitions="*,Auto">

            <Grid Grid.Row="0" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackdropTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <ScrollView Grid.Row="1" MaximumHeightRequest="780">
                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}" Padding="0"
                    Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.12" Offset="0,-2" Radius="16"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2"
                             BackgroundColor="#D0D5EE"
                             HorizontalOptions="Center" Margin="0,14,0,0" />

                        <VerticalStackLayout Padding="20,16,20,40" Spacing="0">

                            <!-- Fila superior: corazón (izquierda) + cerrar (derecha) -->
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,4">
                                <!-- Corazón + contador -->
                                <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <Label x:Name="LblHeart" Text="🤍" FontSize="22" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnHeartTapped" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <Label x:Name="LblLikesCount" Text="0" FontSize="12"
                                           TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <!-- Botón cerrar -->
                                <Border Grid.Column="2"
                                        BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}" Padding="0"
                                        WidthRequest="34" HeightRequest="34"
                                        Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="17"/>
                                    </Border.StrokeShape>
                                    <Label Text="✕" FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCloseTapped" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                            </Grid>

                            <!-- Cabecera -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,4,0,0">
                                <!-- Avatar: inicial + foto superpuesta -->
                                <Grid Grid.Column="0" WidthRequest="72" HeightRequest="72">
                                    <Border BackgroundColor="{AppThemeBinding Light=#E8EAFF, Dark=#1E2040}" Padding="0"
                                        WidthRequest="72" HeightRequest="72"
                                        Stroke="Transparent" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="36"/>
                                        </Border.StrokeShape>
                                        <Label x:Name="LblInicial" Text="?"
                                           FontFamily="OpenSansSemibold" FontSize="28"
                                           TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Border x:Name="ImgFotoBorder"
                                        Stroke="Transparent" StrokeThickness="0"
                                        WidthRequest="72" HeightRequest="72"
                                        IsVisible="False">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="36"/>
                                        </Border.StrokeShape>
                                        <Image x:Name="ImgFoto"
                                               Aspect="AspectFill"
                                               WidthRequest="72" HeightRequest="72" />
                                    </Border>
                                </Grid>
                                <!-- Nombre: toca para ir al perfil público -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnVerPerfilTapped" />
                                    </VerticalStackLayout.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label x:Name="LblNombre" Text=""
                                           FontFamily="OpenSansSemibold"
                                           FontSize="20" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                        <Border x:Name="BadgeVerificado"
                                            BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                                            WidthRequest="20" HeightRequest="20"
                                            Padding="0" Stroke="Transparent" StrokeThickness="0"
                                            VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10"/>
                                            </Border.StrokeShape>
                                            <Image Source="check" WidthRequest="11" HeightRequest="11" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <Label x:Name="LblLocalizacion" Text=""
                                       FontSize="13" TextColor="#9AA0C4" />
                                    <Border x:Name="FrameTag" BackgroundColor="{AppThemeBinding Light=#EEF0FB, Dark=#1E2040}"
                                        Padding="10,4" Stroke="Transparent" StrokeThickness="0"
                                        HorizontalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Label x:Name="LblTag" Text="Cuidador/a"
                                           TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                           FontFamily="OpenSansSemibold" FontSize="11" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- INFORMACIÓN -->
                            <Label Text="INFORMACIÓN" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,20,0,10" />
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                              ColumnSpacing="10" RowSpacing="10">
                                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Padding="12" Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Edad" FontSize="11" TextColor="#9AA0C4" />
                                        <Label x:Name="LblEdad" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Padding="12" Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Tarifa" FontSize="11" TextColor="#9AA0C4" />
                                        <Label x:Name="LblTarifa" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="14" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Padding="12" Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Zona" FontSize="11" TextColor="#9AA0C4" />
                                        <Label x:Name="LblZona" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="13" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Padding="12" Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Reservas" FontSize="11" TextColor="#9AA0C4" />
                                        <Label x:Name="LblReservas" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="13" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <!-- DESCRIPCIÓN -->
                            <Label Text="DESCRIPCIÓN" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,20,0,10" />
                            <Border BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}" Padding="14"
                                Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label x:Name="LblDescripcion" Text=""
                                   FontSize="14" TextColor="{AppThemeBinding Light=#555555, Dark=#DDDDDD}" LineHeight="1.5" />
                            </Border>

                            <!-- DÍAS DISPONIBLES -->
                            <Label Text="DÍAS DISPONIBLES" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,20,0,10" />
                            <FlexLayout x:Name="FlexDias" Wrap="Wrap" Direction="Row" />

                            <!-- FRANJAS HORARIAS -->
                            <Label Text="FRANJAS HORARIAS" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,16,0,10" />
                            <FlexLayout x:Name="FlexFranjas" Wrap="Wrap" Direction="Row" />

                            <!-- MASCOTAS -->
                            <Label Text="MASCOTAS" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,20,0,10" />
                            <Border BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}" Padding="14"
                                Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="¿Tiene o ha tenido mascotas?"
                                           FontSize="12" TextColor="#9AA0C4" />
                                        <Label x:Name="LblTieneMascotas" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                    </VerticalStackLayout>
                                    <Image Source="paw" WidthRequest="24" HeightRequest="24" x:Name="LblEmojiMascotas" VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                                <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Padding="12" Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Máx. mascotas a cuidar" FontSize="11" TextColor="#9AA0C4" />
                                        <Label x:Name="LblNumMascotas" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="20" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                                    Padding="12" Stroke="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="¿Puede con necesidades especiales?"
                                           FontSize="11" TextColor="#9AA0C4" />
                                        <Label x:Name="LblPuedeNecesidades" Text=""
                                           FontFamily="OpenSansSemibold" FontSize="14" TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Border x:Name="FrameExperiencia"
                                BackgroundColor="#FFEEF4" Padding="14"
                                Stroke="Transparent" StrokeThickness="0"
                                Margin="0,10,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="8">
                                    <Image Source="shield" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                    <Label x:Name="LblExperiencia" Text=""
                                       FontSize="13" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                                       FontFamily="OpenSansSemibold" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- ANIMALES QUE CUIDA -->
                            <Label Text="ANIMALES QUE CUIDA" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,20,0,10" />
                            <FlexLayout x:Name="FlexAnimales" Wrap="Wrap" Direction="Row" />

                            <!-- VALORACIONES -->
                            <Label Text="VALORACIONES" FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="#9AA0C4" CharacterSpacing="1" Margin="0,20,0,10" />
                            <Border BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}" Padding="14"
                                Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label x:Name="LblValoracion" Text="5.0"
                                       FontFamily="OpenSansSemibold" FontSize="36"
                                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" HorizontalOptions="Center" />
                                    <Image Source="star" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" />
                                    <Label x:Name="LblResenas" Text=""
                                       FontSize="13" TextColor="#9AA0C4" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <Button x:Name="BtnContactar" Text="Contactar"
                                BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" TextColor="White"
                                FontFamily="OpenSansSemibold" FontSize="15"
                                CornerRadius="14" HeightRequest="52"
                                Margin="0,20,0,0"
                                Clicked="OnContactarClicked" />

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </ScrollView>
        </Grid>
    </ScrollView>
</ContentPage>