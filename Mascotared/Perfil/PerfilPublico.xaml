<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:Mascotared.Converters"
             xmlns:local="clr-namespace:Mascotared.Perfil"
             x:Class="Mascotared.Perfil.PerfilPublico"
             Title="Perfil"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#0F0F14}">

    <ContentPage.Resources>
        <Color x:Key="Green">#2DCE89</Color>
        <conv:Base64ToImageSourceConverter x:Key="Base64Conv" />

        <Style x:Key="StatValue" TargetType="Label">
            <Setter Property="FontFamily" Value="InterSemiBold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
        <Style x:Key="StatLabel" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
        <Style x:Key="SeccionHeader" TargetType="Label">
            <Setter Property="FontFamily" Value="InterSemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
            <Setter Property="CharacterSpacing" Value="1" />
        </Style>
        <Style x:Key="InfoLabel" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
        </Style>
        <Style x:Key="InfoValue" TargetType="Label">
            <Setter Property="FontFamily" Value="InterSemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
        </Style>
    </ContentPage.Resources>

    <!-- Grid raíz: Row0=contenido, Row1=nav -->
    <Grid RowDefinitions="*,Auto">

        <!-- ══════════════════════════════════════════════════════════
             ROW 0 — ScrollView + overlay del visor de fotos
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- ── CABECERA: avatar + stats ──────────────────────────────── -->
                    <Grid ColumnDefinitions="Auto,*"
                      BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                      Padding="16,20,16,16" ColumnSpacing="24">

                        <Grid Grid.Column="0" WidthRequest="90" HeightRequest="90">
                            <Ellipse x:Name="AvatarRingBlue"
                                 Stroke="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" StrokeThickness="2.5"
                                 WidthRequest="90" HeightRequest="90" IsVisible="False" />
                            <Border StrokeShape="Ellipse" Stroke="White" StrokeThickness="2"
                                WidthRequest="82" HeightRequest="82"
                                HorizontalOptions="Center" VerticalOptions="Center">
                                <Grid>
                                    <Border StrokeShape="Ellipse" BackgroundColor="{AppThemeBinding Light=#E8EAFF, Dark=#1E2040}"
                                        Stroke="Transparent" WidthRequest="82" HeightRequest="82">
                                        <Label x:Name="LabelInicial" FontFamily="InterSemiBold" FontSize="30"
                                           TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Image x:Name="ImgAvatar" Aspect="AspectFill"
                                       WidthRequest="82" HeightRequest="82" IsVisible="False" />
                                </Grid>
                            </Border>
                            <Border x:Name="BadgeOnline" IsVisible="False"
                                StrokeShape="Ellipse" BackgroundColor="{StaticResource Green}"
                                Stroke="White" StrokeThickness="2"
                                WidthRequest="16" HeightRequest="16"
                                HorizontalOptions="End" VerticalOptions="End"
                                Margin="0,0,4,4" />
                        </Grid>

                        <Grid Grid.Column="1" ColumnDefinitions="*,*,*"
                          VerticalOptions="Center" Margin="0,4,0,0">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                <Label x:Name="LabelNumPosts" Text="—" Style="{StaticResource StatValue}" />
                                <Label Text="Posts" Style="{StaticResource StatLabel}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                                <Label x:Name="LabelNumResenas" Text="—" Style="{StaticResource StatValue}" />
                                <Label Text="Reseñas" Style="{StaticResource StatLabel}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                <Label x:Name="LabelMedia" Text="—" Style="{StaticResource StatValue}" />
                                <Label Text="⭐ Media" Style="{StaticResource StatLabel}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>

                    <!-- ── BIO ───────────────────────────────────────────────────── -->
                    <VerticalStackLayout BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                                     Padding="16,0,16,14" Spacing="5">
                        <Label x:Name="LabelNombreNav" IsVisible="False" />
                        <Label x:Name="LabelNombreCompleto" FontFamily="InterSemiBold" FontSize="16"
                           TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                        <HorizontalStackLayout Spacing="6">
                            <Border x:Name="ChipCuidador" IsVisible="False"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#EEF0FB, Dark=#1E2040}" Stroke="Transparent" Padding="8,4">
                                <Label Text="🐾 Cuidador/a" FontSize="11"
                                   FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                            </Border>
                            <Border x:Name="ChipPropietario" IsVisible="False"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#FFF0F5, Dark=#2A1020}" Stroke="Transparent" Padding="8,4">
                                <Label Text="🏠 Propietario/a" FontSize="11"
                                   FontFamily="InterSemiBold" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label x:Name="LabelUbicacion" FontSize="13" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                        <Label x:Name="LabelBio" FontSize="14"
                           TextColor="{AppThemeBinding Light=#4A4A4A, Dark=#CCCCDD}"
                           LineBreakMode="WordWrap" />
                        <Label x:Name="LabelTarifa" IsVisible="False"
                           FontFamily="InterSemiBold" FontSize="14" TextColor="#22AA55" />

                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <Button x:Name="BtnMensaje" Grid.Column="0"
                                Text="💬 Enviar mensaje"
                                BackgroundColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                TextColor="White" FontFamily="InterSemiBold"
                                FontSize="13" CornerRadius="10"
                                Clicked="OnMensajeTapped" />
                            <Border x:Name="BtnFavorito" Grid.Column="1"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}" Stroke="Transparent"
                                WidthRequest="44" HeightRequest="44"
                                Margin="8,0,0,0">
                                <Label x:Name="IconFavorito" Text="🤍" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFavoritoTapped" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="8" Color="{AppThemeBinding Light=#F4F6FA, Dark=#0F0F14}" />

                    <!-- ── VALORACIONES (desplegable) ─────────────────────────────── -->
                    <VerticalStackLayout x:Name="SeccionResenas" IsVisible="False" Spacing="0">
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14,16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnToggleResenas" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="VALORACIONES"
                                   Style="{StaticResource SeccionHeader}" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center" Margin="0,0,10,0">
                                <Label x:Name="LabelEstrellaMedia" FontFamily="InterSemiBold"
                                       FontSize="18" TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                                <Label Text="⭐" FontSize="14" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Column="2" x:Name="LblChevronResenas" Text="▼"
                                   FontSize="11" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                                   VerticalOptions="Center" />
                        </Grid>
                        <VerticalStackLayout x:Name="ContenidoResenas" IsVisible="False" Spacing="0">
                            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                                        Padding="16,0,16,16">
                                <HorizontalStackLayout x:Name="StackResenas" Spacing="12" />
                            </ScrollView>
                        </VerticalStackLayout>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Margin="16,0" />
                        <BoxView HeightRequest="8" Color="{AppThemeBinding Light=#F4F6FA, Dark=#0F0F14}" />
                    </VerticalStackLayout>

                    <!-- ── INFORMACIÓN ────────────────────────────────────────────── -->
                    <VerticalStackLayout x:Name="SeccionInfo" IsVisible="False" Spacing="0">
                        <Label Text="INFORMACIÓN" Style="{StaticResource SeccionHeader}"
                           Margin="16,14,16,10" />
                        <Grid ColumnDefinitions="*,*" Padding="16,0,16,14"
                          ColumnSpacing="12" RowSpacing="10" RowDefinitions="Auto,Auto">
                            <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="14,12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Edad" Style="{StaticResource InfoLabel}" />
                                    <Label x:Name="LabelEdad" Style="{StaticResource InfoValue}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" x:Name="CardTarifa" IsVisible="False"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="14,12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Tarifa" Style="{StaticResource InfoLabel}" />
                                    <Label x:Name="LabelTarifaCard" FontFamily="InterSemiBold"
                                       FontSize="15" TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.ColumnSpan="2" StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                                Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" Padding="14,12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Descripción personal" Style="{StaticResource InfoLabel}" />
                                    <Label x:Name="LabelBioCard" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#4A4A4A, Dark=#CCCCDD}"
                                       LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                        <Label x:Name="HeaderDias" Text="DÍAS DISPONIBLES"
                           Style="{StaticResource SeccionHeader}"
                           Margin="16,4,16,8" IsVisible="False" />
                        <ScrollView x:Name="ScrollDias" IsVisible="False"
                                Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                                Padding="16,0,16,12">
                            <HorizontalStackLayout x:Name="StackDias" Spacing="8" />
                        </ScrollView>
                        <Label x:Name="HeaderFranjas" Text="FRANJAS HORARIAS"
                           Style="{StaticResource SeccionHeader}"
                           Margin="16,4,16,8" IsVisible="False" />
                        <ScrollView x:Name="ScrollFranjas" IsVisible="False"
                                Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                                Padding="16,0,16,16">
                            <HorizontalStackLayout x:Name="StackFranjas" Spacing="8" />
                        </ScrollView>
                        <BoxView HeightRequest="8" Color="{AppThemeBinding Light=#F4F6FA, Dark=#0F0F14}" />
                    </VerticalStackLayout>

                    <!-- ── MIS MASCOTAS ───────────────────────────────────────────── -->
                    <VerticalStackLayout x:Name="SeccionMascotas" IsVisible="False" Spacing="0">
                        <Label Text="MIS MASCOTAS" Style="{StaticResource SeccionHeader}"
                           Margin="16,14,16,10" />
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                                Padding="16,0,16,16">
                            <HorizontalStackLayout x:Name="StackMascotas" Spacing="14" />
                        </ScrollView>
                        <BoxView HeightRequest="8" Color="{AppThemeBinding Light=#F4F6FA, Dark=#0F0F14}" />
                    </VerticalStackLayout>

                    <!-- ── TABS ───────────────────────────────────────────────────── -->
                    <Grid ColumnDefinitions="*,*"
                      BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}">
                        <VerticalStackLayout Grid.Column="0" Spacing="0" Padding="0,12,0,0">
                            <Label x:Name="TabLabelPosts" Text="⊞  Posts"
                               FontFamily="InterSemiBold" FontSize="13"
                               TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" HorizontalOptions="Center" />
                            <BoxView x:Name="TabLinePosts" HeightRequest="2"
                                 Color="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" Margin="20,8,20,0" />
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabPostsTapped" />
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="0" Padding="0,12,0,0">
                            <Label x:Name="TabLabelOfertas" Text="📋  Ofertas"
                               FontFamily="InterSemiBold" FontSize="13"
                               TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                            <BoxView x:Name="TabLineOfertas" HeightRequest="2"
                                 Color="Transparent" Margin="20,8,20,0" />
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabOfertasTapped" />
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" />

                    <!-- ── GRID DE POSTS ──────────────────────────────────────────── -->
                    <VerticalStackLayout x:Name="PanelPosts" Spacing="0">
                        <VerticalStackLayout x:Name="EstadoVacioPosts" IsVisible="False"
                                         HorizontalOptions="Center" Spacing="10" Margin="0,48,0,48">
                            <Label Text="📸" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="Aún no has publicado nada" FontFamily="InterSemiBold"
                               FontSize="15" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                        </VerticalStackLayout>
                        <CollectionView x:Name="GridPosts" SelectionMode="Single"
                                    SelectionChanged="OnPostSeleccionado">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3"
                                             HorizontalItemSpacing="2" VerticalItemSpacing="2" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="local:PostPublicoItem">
                                    <Grid WidthRequest="132" HeightRequest="132">
                                        <Image Source="{Binding ImagenUrl, Converter={StaticResource Base64Conv}}"
                                           Aspect="AspectFill" WidthRequest="132" HeightRequest="132" />
                                        <Border BackgroundColor="#55000000" StrokeShape="Rectangle"
                                            Stroke="Transparent" IsVisible="{Binding TieneLikes}"
                                            VerticalOptions="End" HeightRequest="26">
                                            <Label Text="{Binding LikesTexto}" FontSize="11"
                                               FontFamily="InterSemiBold" TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- ── LISTA DE OFERTAS ───────────────────────────────────────── -->
                    <VerticalStackLayout x:Name="PanelOfertas" IsVisible="False"
                                     Padding="12,12,12,0" Spacing="0">
                        <VerticalStackLayout x:Name="EstadoVacioOfertas" IsVisible="False"
                                         HorizontalOptions="Center" Spacing="10" Margin="0,48,0,48">
                            <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                            <Label Text="Sin ofertas activas" FontFamily="InterSemiBold"
                               FontSize="15" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                        </VerticalStackLayout>
                        <CollectionView x:Name="ListaOfertas" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="local:OfertaPublicaItem">
                                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A24}"
                                        StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}"
                                        Padding="14,12" Margin="0,0,0,10">
                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border Grid.Column="0" StrokeShape="RoundRectangle 12"
                                                    Stroke="Transparent" WidthRequest="60" HeightRequest="60"
                                                    BackgroundColor="{AppThemeBinding Light=#EEF0FB, Dark=#1E2040}">
                                                    <Image Source="{Binding FotoPath}" Aspect="AspectFill"
                                                       WidthRequest="60" HeightRequest="60">
                                                        <Image.Triggers>
                                                            <DataTrigger TargetType="Image"
                                                                     Binding="{Binding FotoPath}" Value="">
                                                                <Setter Property="Source" Value="placeholder_pet.png" />
                                                            </DataTrigger>
                                                        </Image.Triggers>
                                                    </Image>
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                    <Label Text="{Binding Titulo}"
                                                       FontFamily="InterSemiBold" FontSize="14"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                                                    <Label Text="{Binding Localizacion}"
                                                       FontSize="12" TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" />
                                                    <Border StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                                        BackgroundColor="{AppThemeBinding Light=#EEF0FB, Dark=#1E2040}" Padding="6,3"
                                                        HorizontalOptions="Start">
                                                        <Label Text="{Binding TagTexto}"
                                                           FontSize="10" FontFamily="InterSemiBold"
                                                           TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}" />
                                                    </Border>
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2" Text="{Binding PrecioTexto}"
                                                   FontFamily="InterSemiBold" FontSize="13"
                                                   TextColor="#22AA55" VerticalOptions="Center" />
                                            </Grid>
                                            <VerticalStackLayout IsVisible="{Binding TieneMascotas}" Spacing="6">
                                                <Label Text="MASCOTAS" FontSize="10"
                                                   FontFamily="InterSemiBold"
                                                   TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" CharacterSpacing="1" />
                                                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                                    <HorizontalStackLayout Spacing="10"
                                                    BindableLayout.ItemsSource="{Binding Mascotas}">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate x:DataType="local:MascotaOfertaItem">
                                                                <VerticalStackLayout Spacing="4" WidthRequest="60" HorizontalOptions="Center">
                                                                    <Border StrokeShape="Ellipse"
                                                                        BackgroundColor="{AppThemeBinding Light=#E8EAFF, Dark=#1E2040}"
                                                                        Stroke="Transparent"
                                                                        WidthRequest="48" HeightRequest="48"
                                                                        HorizontalOptions="Center">
                                                                        <Label Text="{Binding Emoji}" FontSize="22"
                                                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                                                    </Border>
                                                                    <Label Text="{Binding Nombre}" FontSize="11"
                                                                       FontFamily="InterSemiBold"
                                                                       TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                                                                       HorizontalOptions="Center"
                                                                       HorizontalTextAlignment="Center"
                                                                       LineBreakMode="TailTruncation" />
                                                                </VerticalStackLayout>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </HorizontalStackLayout>
                                                </ScrollView>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="40" Color="Transparent" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- ── OVERLAY VISOR DE FOTOS (estilo Instagram full-screen) ─────── -->
            <Grid x:Name="OverlayVisor" IsVisible="False"
                  BackgroundColor="Black"
                  VerticalOptions="Fill" HorizontalOptions="Fill">

                <Grid.GestureRecognizers>
                    <SwipeGestureRecognizer Direction="Left"  Swiped="OnSwipeVisor" />
                    <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipeVisor" />
                    <SwipeGestureRecognizer Direction="Down"  Swiped="OnCerrarVisorSwipe" />
                </Grid.GestureRecognizers>

                <Image x:Name="VisorImagen" Aspect="AspectFit"
                       VerticalOptions="Center" HorizontalOptions="Fill" />

                <BoxView VerticalOptions="Start" HeightRequest="110"
                         BackgroundColor="#88000000" InputTransparent="True" />

                <Grid VerticalOptions="Start" ColumnDefinitions="Auto,*,Auto"
                      Padding="12,46,8,0" ColumnSpacing="10">
                    <Grid Grid.Column="0" WidthRequest="36" HeightRequest="36">
                        <Border x:Name="VisorAvatarBg" StrokeShape="Ellipse"
                                BackgroundColor="{AppThemeBinding Light=#E8EAFF, Dark=#1E2040}" Stroke="Transparent"
                                WidthRequest="36" HeightRequest="36">
                            <Label x:Name="VisorInicial"
                                   FontFamily="InterSemiBold" FontSize="15"
                                   TextColor="{AppThemeBinding Light=#455AEB, Dark=#5C6CFF}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Image x:Name="VisorAvatar" Aspect="AspectFill"
                               WidthRequest="36" HeightRequest="36" IsVisible="False">
                            <Image.Clip>
                                <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18" />
                            </Image.Clip>
                        </Image>
                    </Grid>
                    <Label Grid.Column="1" x:Name="VisorNombre"
                           FontFamily="InterSemiBold" FontSize="14"
                           TextColor="White" VerticalOptions="Center" />
                    <Label Grid.Column="2" Text="✕" FontSize="22"
                           TextColor="White" WidthRequest="44" HeightRequest="44"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCerrarVisorTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Border x:Name="ContadorBorder" IsVisible="False"
                        VerticalOptions="Start" HorizontalOptions="End"
                        Margin="0,52,12,0"
                        BackgroundColor="#66000000" Stroke="Transparent"
                        StrokeShape="RoundRectangle 12" Padding="10,4">
                    <Label x:Name="VisorContador"
                           FontFamily="InterSemiBold" FontSize="12" TextColor="White" />
                </Border>

                <Label x:Name="VisorFlechaAnterior" Text="❮" FontSize="26"
                       TextColor="White" HorizontalOptions="Start"
                       VerticalOptions="Center" Margin="10,0" Opacity="0.8">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVisorAnteriorTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="VisorFlechaSiguiente" Text="❯" FontSize="26"
                       TextColor="White" HorizontalOptions="End"
                       VerticalOptions="Center" Margin="10,0" Opacity="0.8">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVisorSiguienteTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <BoxView VerticalOptions="End" HeightRequest="200"
                         BackgroundColor="#99000000" InputTransparent="True" />

                <VerticalStackLayout VerticalOptions="End" Spacing="0" Padding="0,0,0,30">
                    <HorizontalStackLayout x:Name="VisorPuntos"
                                           HorizontalOptions="Center"
                                           Spacing="6" Margin="0,0,0,10" />
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                          Padding="14,0,14,6" ColumnSpacing="18">
                        <Label Grid.Column="0" x:Name="VisorBotonLike"
                               Text="♡" FontSize="28" TextColor="White"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVisorLikeTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Grid.Column="1" Text="💬" FontSize="24"
                               TextColor="White" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVisorComentariosTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Grid.Column="3" Text="🔖" FontSize="22"
                               TextColor="White" VerticalOptions="Center" />
                    </Grid>
                    <Label x:Name="VisorLikes"
                           FontFamily="InterSemiBold" FontSize="13" TextColor="White"
                           Margin="14,0,14,2" />
                    <Label x:Name="VisorComentarios"
                           FontSize="13" TextColor="#BBBBBB"
                           Margin="14,0,14,4" IsVisible="False">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVisorComentariosTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label x:Name="VisorDescripcion"
                           FontSize="13" TextColor="#DDDDDD"
                           LineBreakMode="WordWrap" MaxLines="3"
                           Margin="14,0,14,0" />
                </VerticalStackLayout>

            </Grid>
        </Grid>

        <!-- ── OVERLAY COMENTARIOS (bottom sheet) ──────────────────────────── -->
        <Grid x:Name="OverlayComentarios" Grid.RowSpan="2" IsVisible="False"
              BackgroundColor="#AA000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCerrarComentariosTapped" />
            </Grid.GestureRecognizers>
            <VerticalStackLayout VerticalOptions="End"
                                 BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1F2E}">
                <Grid.GestureRecognizers>
                    <!-- Evitar que el tap en el panel cierre el overlay -->
                </Grid.GestureRecognizers>
                <!-- Handle -->
                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2"
                         Color="{AppThemeBinding Light=#D0D5EE, Dark=#3A3A4A}"
                         HorizontalOptions="Center" Margin="0,10,0,0" />
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Padding="16,12,16,12">
                    <Label Text="Comentarios" FontFamily="InterSemiBold" FontSize="16"
                           TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}" />
                    <Label Grid.Column="1" Text="✕" FontSize="20"
                           TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                           WidthRequest="36" HorizontalTextAlignment="End">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCerrarComentariosTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
                <BoxView HeightRequest="1"
                         Color="{AppThemeBinding Light=#EEF0FB, Dark=#2E2E3C}" />
                <!-- Lista de comentarios -->
                <ScrollView MaximumHeightRequest="320">
                    <VerticalStackLayout x:Name="StackComentariosVisor"
                                         Padding="16,10" Spacing="14" />
                </ScrollView>
                <!-- Entrada nuevo comentario -->
                <Grid ColumnDefinitions="*,Auto" Padding="16,10,16,20" ColumnSpacing="10">
                    <Border BackgroundColor="{AppThemeBinding Light=#F4F6FA, Dark=#22222E}"
                            Padding="14,8" Stroke="Transparent" Grid.Column="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Entry x:Name="EntryNuevoComentario"
                               Placeholder="Añade un comentario..."
                               PlaceholderColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}"
                               TextColor="{AppThemeBinding Light=#2C2C2C, Dark=White}"
                               FontSize="13" BackgroundColor="Transparent"
                               ReturnCommand="{Binding Source={x:Reference EntryNuevoComentario}, Path=ReturnCommand}" />
                    </Border>
                    <Label Grid.Column="1" Text="Publicar" FontFamily="InterSemiBold"
                           FontSize="13" TextColor="#455AEB" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPublicarComentarioTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </VerticalStackLayout>
        </Grid>

        <!-- fin Grid Row 0 -->

        <!-- ══════════════════════════════════════════════════════════
             ROW 1 — BOTTOM NAV
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#252836}"
              ColumnDefinitions="*,*,*,*,*" Padding="0,10,0,30">
            <Grid.Shadow>
                <Shadow Brush="Black" Opacity="0.06" Offset="0,-4" Radius="12" />
            </Grid.Shadow>
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                <Image Source="search" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Explorar" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBuscarTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                <Image Source="heart" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Favoritos" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFavoritosTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                <Image Source="calendar" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Solicitudes" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnReservasTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                <Image Source="message" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Mensajes" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#9AA0C4, Dark=#7B82B0}" HorizontalOptions="Center" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMensajesTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4">
                <Image Source="user" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" />
                <Label Text="Cuenta" FontSize="10" FontFamily="InterSemiBold"
                       TextColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}" HorizontalOptions="Center" />
                <BoxView HeightRequest="3" WidthRequest="30"
                         BackgroundColor="{AppThemeBinding Light=#FE3D7D, Dark=#FF4F8F}"
                         CornerRadius="1.5" HorizontalOptions="Center" Margin="0,2,0,0" />
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCuentaTapped" />
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

    </Grid>
    <!-- fin Grid raíz -->

</ContentPage>