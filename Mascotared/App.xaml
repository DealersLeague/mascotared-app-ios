<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Mascotared"
             xmlns:conv="clr-namespace:Mascotared.Converters"
             x:Class="Mascotared.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters globales — disponibles en todos los XAML de la app -->
            <conv:Base64ToImageSourceConverter x:Key="Base64Conv"/>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
